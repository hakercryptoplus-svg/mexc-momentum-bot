# Environment variables required to run the bot
# Copy this to .env and fill in your values

# === REQUIRED ===
# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (numeric)
TELEGRAM_CHAT_ID=your_chat_id_here

# === OPTIONAL (set via /set_mexc in Telegram instead) ===
# MEXC API Key
MEXC_API_KEY=
# MEXC Secret Key
MEXC_SECRET_KEY=

# === OPTIONAL: Override trading parameters ===
# MIN_PUMP=5.0
# TAKE_PROFIT=1.02
# STOP_LOSS=0.99
# RISK_PER_TRADE=1.0
# FEE=0.001

# === OPTIONAL: Custom coin watchlist (comma-separated) ===
# COINS=BEAT/USDT,ETH/USDT,BTC/USDT

# === OPTIONAL: Schedule ===
# SCAN_HOUR=0
# SCAN_MINUTE=5

# === OPTIONAL: State file directory (default: current dir) ===
# STATE_DIR=/data
